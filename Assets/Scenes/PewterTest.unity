  m_Script: {fileID: 11500000, guid: 1a5d2d47ed591144ebaa16c2e26cc463, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BasicRPG.UI.TutorialOverlay
  title: "Pewter \u2014 Physical Enhancement"
  steps:
  - text: "Pewter \u2014 physical enhancement. Press TAB to open the metal wheel."
    type: 1
    key: 9
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: Click Pewter (slot 3) or press 3 to make it the active metal.
    type: 3
    key: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Close the wheel (Esc or click) if it's open, then press B to burn Pewter
      \u2014 you're stronger, faster, tougher."
    type: 4
    key: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "The arena is live now. LMB the dummy (~2\xD7 damage), Space to jump the
      gap (Pewter clears it), take a hit (~35% less). Burn >~30s then stop = drag
      crash. Hold R to flare. Press any key to finish."
    type: 0
    key: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  stepGrace: 0.35
  overloadThreshold: 0.1
  skipKey: 8
