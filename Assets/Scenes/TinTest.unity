--- !u!114 &868832344
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 868832343}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1a5d2d47ed591144ebaa16c2e26cc463, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BasicRPG.UI.TutorialOverlay
  title: "Tin \u2014 Enhanced Senses"
  steps:
  - text: "Tin \u2014 enhanced senses. The arena is nearly pitch black. Press TAB
      to open the metal wheel."
    type: 1
    key: 9
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: Click Tin (slot 4) or press 4 to make it the active metal.
    type: 3
    key: 0
    metal: 3
    freeze: 1
    waitSeconds: 0
  - text: "Close the wheel (Esc or click) if it's open, then press B to burn Tin
      \u2014 the world brightens (night vision)."
    type: 4
    key: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Now WALK to the glowing light to feel sensory overload (the cost of Tin).
      The arena is live \u2014 move!"
    type: 6
    key: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: "Overload whites out the screen, muffles audio and slows you \u2014 step
      away to recover. Hold R to flare (sharper but faster overload + drain). Tutorial
      complete \u2014 explore!"
    type: 0
    key: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  stepGrace: 0.35
  overloadThreshold: 0.1
  skipKey: 8
