--- !u!114 &1174098059
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1174098058}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1a5d2d47ed591144ebaa16c2e26cc463, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BasicRPG.UI.TutorialOverlay
  title: "Copper & Bronze \u2014 Hide / Sense Allomancers"
  steps:
  - text: "Copper & Bronze \u2014 hide/sense allomancers. The two dark-red Thugs
      are Pewter-burning enemies (faster + hit harder). The plain red Grunt is normal.
      Press TAB (or Share) to open the metal wheel."
    type: 2
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Click Bronze (slot 6) or press 6 \u2014 let's sense first."
    type: 3
    key: 0
    padKey: 0
    metal: 5
    freeze: 1
    waitSeconds: 0
  - text: "Close the wheel if it's open, then press B to burn Bronze \u2014 hear
      the Thugs' allomantic pulses (directional pings + toast)."
    type: 4
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: Toasts report how many allomancers are near. Press any key to continue
      to Copper.
    type: 0
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: Now press TAB (or Share) to open the wheel and switch metals.
    type: 2
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: Click Copper (slot 5) or press 5.
    type: 3
    key: 0
    padKey: 0
    metal: 4
    freeze: 1
    waitSeconds: 0
  - text: "Press B to burn Copper \u2014 emit a coppercloud that SUPPRESSES nearby
      Thugs."
    type: 4
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "The arena is live. APPROACH a Thug to suppress it \u2014 it turns grey-blue,
      slows and hits weaker."
    type: 7
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: "Step away (out of the cloud) and it resumes burning + re-buffs. Hold R
      to flare (wider cloud/pulse). Tutorial complete \u2014 press Enter (or Dpad\u2193)
      when you're done."
    type: 1
    key: 13
    padKey: 343
    metal: 2
    freeze: 0
    waitSeconds: 0
  stepGrace: 0.35
  overloadThreshold: 0.1
  skipKey: 8
  padSkip: 343
