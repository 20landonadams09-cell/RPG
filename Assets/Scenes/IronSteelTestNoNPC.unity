  m_Script: {fileID: 11500000, guid: 1a5d2d47ed591144ebaa16c2e26cc463, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BasicRPG.UI.TutorialOverlay
  title: "Iron & Steel \u2014 Push / Pull on Metal"
  steps:
  - text: "Iron & Steel \u2014 push/pull on METAL. The shiny metallic cubes are anchors.
      While burning, blue sight lines show every metal in range \u2014 the THICKEST
      line points to the NEAREST metal (your default target). Press TAB (or Share)
      to open the metal wheel."
    type: 2
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Click Steel (slot 2) or press 2 \u2014 let's push first."
    type: 3
    key: 0
    padKey: 0
    metal: 1
    freeze: 1
    waitSeconds: 0
  - text: Close the wheel (Esc or click) if it's open, then press B to burn Steel.
    type: 4
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "The thickest blue line marks the NEAREST metal \u2014 that's your target.
      HOLD LEFT MOUSE to Steelpush it. A NAILED grey cube won't move; YOU launch
      off it (full recoil). The arena is live now."
    type: 5
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: "HOLD RIGHT MOUSE while pushing to FLARE (burn harder \u2014 stronger push,
      faster drain). HOLD MIDDLE MOUSE to freeze time and pick a DIFFERENT metal
      as your target (move the mouse onto it, release to lock)."
    type: 5
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: "Now push a COPPER cube \u2014 those are LOOSE. The small coin flies off
      and barely moves you; the heavy block barely budges and shoves YOU back. Same
      force, lighter body moves more \u2014 Newton's third law. Then try the LAUNCH
      PLATE: stand on the flat metal plate, jump, and hold LMB pushing straight DOWN
      to launch upward."
    type: 5
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: Nice. Now let's pull. Press TAB (or Share) to switch metals.
    type: 2
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: Click Iron (slot 1) or press 1.
    type: 3
    key: 0
    padKey: 0
    metal: 0
    freeze: 1
    waitSeconds: 0
  - text: Press B to burn Iron.
    type: 4
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "The nearest metal is your target (gold line). HOLD LEFT MOUSE to Ironpull
      \u2014 yank toward it (or yank a loose coin back to you)."
    type: 5
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: "Heavier anchors reach farther; loose metal is a mass-split (lighter body
      moves more); LMB = push/pull, RMB = flare, MMB = freeze-aim. Tutorial complete
      \u2014 press Enter (or Dpad\u2193) when you're done exploring."
    type: 1
    key: 13
    padKey: 343
    metal: 2
    freeze: 0
    waitSeconds: 0
  stepGrace: 0.35
  overloadThreshold: 0.1
  skipKey: 8
  padSkip: 343
