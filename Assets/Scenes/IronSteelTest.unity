--- !u!114 &1467589083
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1467589082}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1a5d2d47ed591144ebaa16c2e26cc463, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BasicRPG.UI.TutorialOverlay
  title: "Iron & Steel \u2014 Push / Pull on Metal"
  steps:
  - text: "Iron & Steel \u2014 push/pull on METAL. The shiny metallic cubes (and
      the armored enemies) are anchors; a sight line shows your target. Press TAB
      (or Share) to open the metal wheel."
    type: 2
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Click Steel (slot 2) or press 2 \u2014 let's push first."
    type: 3
    key: 0
    padKey: 0
    metal: 1
    freeze: 1
    waitSeconds: 0
  - text: Close the wheel (Esc or click) if it's open, then press B to burn Steel.
    type: 4
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Aim at a NAILED grey cube (a blue line marks your target) and HOLD F to
      Steelpush \u2014 it won't move; YOU launch off it (full recoil). The arena
      is live now."
    type: 5
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: "Now push a COPPER cube \u2014 those are LOOSE (not nailed). The small
      coin flies off and barely moves you; the big heavy block barely budges and
      shoves YOU back. Same force, lighter body moves more \u2014 Newton's third
      law."
    type: 5
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: Nice. Now let's pull. Press TAB (or Share) to switch metals.
    type: 2
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: Click Iron (slot 1) or press 1.
    type: 3
    key: 0
    padKey: 0
    metal: 0
    freeze: 1
    waitSeconds: 0
  - text: Press B to burn Iron.
    type: 4
    key: 0
    padKey: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Aim at an anchor (a gold line marks your target) and HOLD Q to Ironpull
      \u2014 yank toward it (or yank a loose coin back to you)."
    type: 5
    key: 0
    padKey: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: "Heavier anchors reach farther; loose metal is a mass-split (lighter body
      moves more); shoving an enemy recoils you too; hold R to flare. Tutorial complete
      \u2014 press Enter (or Dpad\u2193) when you're done exploring."
    type: 1
    key: 13
    padKey: 343
    metal: 2
    freeze: 0
    waitSeconds: 0
  stepGrace: 0.35
  overloadThreshold: 0.1
  skipKey: 8
  padSkip: 343
