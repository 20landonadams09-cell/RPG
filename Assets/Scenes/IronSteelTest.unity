--- !u!114 &1259711439
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1259711438}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1a5d2d47ed591144ebaa16c2e26cc463, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BasicRPG.UI.TutorialOverlay
  title: "Iron & Steel \u2014 Push / Pull on Metal"
  steps:
  - text: "Iron & Steel \u2014 push/pull on METAL. The shiny metallic cubes (and
      the armored enemies) are anchors; a sight line shows your target. Press TAB
      to open the metal wheel."
    type: 1
    key: 9
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Click Steel (slot 2) or press 2 \u2014 let's push first."
    type: 3
    key: 0
    metal: 1
    freeze: 1
    waitSeconds: 0
  - text: Close the wheel (Esc or click) if it's open, then press B to burn Steel.
    type: 4
    key: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Aim at a metal cube (a blue line marks your target) and HOLD F to Steelpush
      \u2014 launch off it. The arena is live now."
    type: 5
    key: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: Nice. Now let's pull. Press TAB to switch metals.
    type: 1
    key: 9
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: Click Iron (slot 1) or press 1.
    type: 3
    key: 0
    metal: 0
    freeze: 1
    waitSeconds: 0
  - text: Press B to burn Iron.
    type: 4
    key: 0
    metal: 2
    freeze: 1
    waitSeconds: 0
  - text: "Aim at an anchor (a gold line marks your target) and HOLD Q to Ironpull
      \u2014 yank toward it."
    type: 5
    key: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  - text: "Heavier anchors reach farther; shoving an enemy recoils you too (mass-split);
      hold R to flare. Tutorial complete \u2014 explore!"
    type: 0
    key: 0
    metal: 2
    freeze: 0
    waitSeconds: 0
  stepGrace: 0.35
  overloadThreshold: 0.1
  skipKey: 8
